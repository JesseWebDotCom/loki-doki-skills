{
  "schema_version": 1,
  "id": "weather",
  "title": "Weather",
  "domain": "weather",
  "description": "Return current weather summaries for a location.",
  "logo_path": "logo-weather.svg",
  "version": "1.0.0",
  "load_type": "lazy",
  "account_mode": "none",
  "system": false,
  "enabled_by_default": true,
  "required_context": [],
  "optional_context": ["location", "timezone"],
  "permissions": {
    "default": "all_users"
  },
  "shared_context_fields": [
    {
      "key": "location",
      "label": "Default location",
      "type": "text",
      "placeholder": "Milford, CT",
      "help_text": "Used when a weather request does not mention a location.",
      "required": false,
      "default_value": ""
    },
    {
      "key": "timezone",
      "label": "Timezone",
      "type": "text",
      "placeholder": "America/New_York",
      "help_text": "Used for date-sensitive weather prompts.",
      "required": false,
      "default_value": "America/New_York"
    }
  ],
  "account_context_fields": [],
  "runtime_dependencies": [],
  "skill_dependencies": {
    "required": [
      {
        "id": "web_search",
        "reason": "Weather uses the built-in search provider for live weather data."
      }
    ],
    "optional": []
  },
  "actions": {
    "get_weather": {
      "title": "Get Weather",
      "description": "Return the weather for a requested location.",
      "enabled": true,
      "required_context": [],
      "optional_context": ["location", "timezone"],
      "timeout_ms": 5000,
      "cache_ttl_sec": 300,
      "phrases": [
        "weather",
        "forecast",
        "temperature",
        "will it rain",
        "is it raining",
        "going to rain",
        "will it snow",
        "is it snowing",
        "going to snow",
        "will it hail",
        "is it hailing",
        "going to hail",
        "will it sleet",
        "is it sleeting",
        "going to sleet",
        "chance of rain",
        "chance of snow",
        "chance of hail",
        "chance of sleet",
        "need an umbrella",
        "outside today",
        "outside tonight"
      ],
      "keywords": [
        "weather",
        "forecast",
        "temperature",
        "rain",
        "raining",
        "rainy",
        "drizzle",
        "shower",
        "showers",
        "downpour",
        "snow",
        "snowing",
        "snowfall",
        "flurries",
        "blizzard",
        "sleet",
        "sleeting",
        "hail",
        "hailing",
        "freezing",
        "freezing_rain",
        "precipitation",
        "umbrella",
        "wind",
        "windy",
        "gust",
        "gusty",
        "storm",
        "stormy",
        "thunderstorm",
        "lightning",
        "sunny",
        "cloudy",
        "overcast",
        "humid",
        "humidity",
        "hot",
        "cold",
        "warm",
        "cool",
        "outside",
        "today",
        "tonight",
        "tomorrow"
      ],
      "negative_keywords": ["movie", "calendar", "lights", "search"],
      "example_utterances": [
        "what's the weather in milford ct today",
        "forecast tonight in boston",
        "is it going to snow",
        "will it hail later today",
        "is there sleet tonight in milford",
        "do i need an umbrella",
        "is it windy outside today"
      ],
      "required_entities": [],
      "optional_entities": ["location", "date"]
    }
  }
}
